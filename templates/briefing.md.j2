<div class="masthead">
<div class="masthead-rule-thick"></div>
<div class="masthead-title">The Daily Telegram</div>
<div class="masthead-rule-double"></div>
<div class="masthead-meta">{{ content.date.strftime('%A, %-d %B %Y') }} &nbsp;·&nbsp; Daily Edition</div>
<div class="masthead-rule-thin"></div>
</div>

## Executive Summary

{% for item in content.main_items[:10] %}
{% set username = content.channel_links.get(item.post.channel_name, '') %}
- {{ threat_badge(item.analysis.threat_level) }} · `{{ item.analysis.category }}` — {{ item.analysis.title if item.analysis.title else item.analysis.summary[:90] ~ ('…' if item.analysis.summary|length > 90 else '') }} _({{ item.post.channel_name }}, {{ item.post.timestamp.strftime('%H:%M UTC') }}{% if username %}, [↗ t.me](https://t.me/{{ username }}/{{ item.post.message_id }}){% endif %})_
{% else %}
_No high-priority items today._
{% endfor %}

{% for channel in content.channel_names %}
## Channel: {{ channel }}

{% set username = content.channel_links.get(channel, '') %}

{% for item in content.main_items if item.post.channel_name == channel %}
{% if item.analysis.summary %}
### {{ threat_badge(item.analysis.threat_level) }} · `{{ item.analysis.category }}` · **{{ item.analysis.title if item.analysis.title else item.analysis.summary[:90] ~ ('…' if item.analysis.summary|length > 90 else '') }}**

<small>{{ item.post.timestamp.strftime('%H:%M UTC') }} · Score {{ "%.1f"|format(item.composite_score) }}/5 · ID {{ item.post.message_id }}{% if username %} · [↗ t.me](https://t.me/{{ username }}/{{ item.post.message_id }}){% endif %}</small>

{{ item.analysis.summary }}

**Entities:** {{ item.analysis.key_entities | clean_entities | join(', ') or '—' }}

{% if item.analysis.image_insights and item.analysis.image_insights | lower not in ('n/a', 'none', 'no image provided', 'no image provided.', 'no image.') and item.analysis.image_insights | length > 10 %}
**Image:** {{ item.analysis.image_insights }}
{% endif %}

{% if item.post.has_video %}
**Video:** _[▶ Watch on Telegram](https://t.me/{{ username }}/{{ item.post.message_id }})_
{% endif %}

{% if item.post.media_paths %}
{% for img in item.post.media_paths[:3] %}
![]({{ img }})
{% endfor %}
{% endif %}

---
{% endif %}
{% else %}
_No posts above threshold for this channel._
{% endfor %}

{% endfor %}

{% if content.appendix_items %}
## Appendix — Lower Priority Items

<div class="appendix-cols">
{% for item in content.appendix_items %}
{% set username = content.channel_links.get(item.post.channel_name, '') %}
<div class="appendix-item">
<span class="a-channel">{{ item.post.channel_name }}</span> <span class="a-time">{{ item.post.timestamp.strftime('%H:%M UTC') }}</span> · <span class="cat-slug">{{ item.analysis.category }}</span><br>
{{ item.analysis.summary }} <span class="a-score">({{ "%.1f"|format(item.composite_score) }}/5{% if username %} · <a href="https://t.me/{{ username }}/{{ item.post.message_id }}">↗</a>{% endif %})</span>
</div>
{% endfor %}
</div>
{% endif %}

## Statistics

| Metric | Value |
|--------|-------|
| Total posts | {{ content.main_items|length + content.appendix_items|length }} |
| Main briefing | {{ content.main_items|length }} |
| Appendix | {{ content.appendix_items|length }} |
| Channels | {{ content.channel_names | join(', ') or '—' }} |
{%- for cat, count in content.category_counts | dictsort(by='value', reverse=true) %}
| {{ cat }} | {{ count }} |
{%- endfor %}
